# ---------------------------------------------------------------------------
# PayPro (Pakistan) — secrets. Fill the XXXX values; never commit the real .env
# ---------------------------------------------------------------------------
# Sandbox/demo base while testing, then switch to the production base PayPro
# gives you at go-live (commonly https://api.paypro.com.pk — confirm with them).
PAYPRO_BASE_URL=https://demoapi.paypro.com.pk

PAYPRO_MERCHANT_ID=Engs_Tech
PAYPRO_USERNAME=Engs_Tech
PAYPRO_PASSWORD=XXXX
PAYPRO_CLIENT_ID=XXXX
PAYPRO_CLIENT_SECRET=XXXX

# Comma-separated PayPro server IPs allowed to hit the IPN endpoint.
# Ask PayPro for their IPN source IPs and lock the webhook to them.
PAYPRO_IPN_ALLOWED_IPS=

# Public URL of your IPN/callback (configure the same value in the PayPro portal)
PAYPRO_RETURN_URL=https://yaad.engstech.com/billing/paypro/ipn

# Order-status endpoint used to re-verify a payment (VERIFY exact path in Postman)
PAYPRO_STATUS_PATH=/v2/ppro/ggosboi
# true = never activate on an unverified IPN (recommended once status endpoint is confirmed)
PAYPRO_STRICT_VERIFY=true

# ---------------------------------------------------------------------------
# Abuse controls / rate limits
# ---------------------------------------------------------------------------
SCAN_PER_MIN=8
SCAN_PER_HOUR=60
SCAN_PER_DAY=200
IP_SCAN_PER_MIN=20
SIGNUP_PER_IP_PER_DAY=5

# ---------------------------------------------------------------------------
# Pricing
# ---------------------------------------------------------------------------
FREE_SHEETS=10
PLAN_PRICE_PKR=200
PLAN_PERIOD_DAYS=30

# ---------------------------------------------------------------------------
# Other app secrets (kept here so everything lives in one place)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://yaad:XXXX@localhost:5432/yaad
REDIS_URL=redis://localhost:6379/0

GEMINI_API_KEY=XXXX        # OCR via Gemini vision
GROQ_API_KEY=XXXX          # card generation
# MISTRAL_API_KEY=XXXX     # unused (Gemini chosen for OCR)

# Capture -> OCR -> cards pipeline
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-2.0-flash
OCR_PRIMARY=tesseract
MAX_UPLOAD_MB=8

# Passwordless auth (email OTP + JWT)
RESEND_API_KEY=XXXX                       # Resend API key for OTP email
RESEND_FROM=noreply@yaad.engstech.com     # must be a Resend-verified sender
SECRET_KEY=generate_with_secrets_token_hex_32   # JWT signing key
ACCESS_TOKEN_TTL_DAYS=30
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=5
RECONCILE_GRACE_MINUTES=10
